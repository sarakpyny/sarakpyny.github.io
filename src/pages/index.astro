---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sarakpy NY">
  <section class="hero">
    <div class="hero-text">
      <h1>Sarakpy NY</h1>

      <p class="subtitle">
        MSc student in DS, Statistics, and ML at
        <a
          href="https://www.ensae.fr/"
          target="_blank"
          rel="noopener noreferrer">ENSAE</a
        >
        –
        <a
          href="https://www.ip-paris.fr/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Institut Polytechnique de Paris (IP Paris)
        </a>
      </p>

      <div class="lead">
        <p>
          I am a master's student at
          <a
            href="https://www.ensae.fr/"
            target="_blank"
            rel="noopener noreferrer">ENSAE</a
          >
          –
          <a
            href="https://www.ip-paris.fr/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Institut Polytechnique de Paris (IP Paris)
          </a>, with a background in applied mathematics and statistics.
        </p>
        <p>
          My interests include the intersection of machine learning, artificial
          intelligence, statistical learning, and scientific modeling.
        </p>
      </div>

      <div class="hero-links">
        <a class="text-link" href="/about">About</a>
        <a class="text-link" href="/projects">Projects</a>
        <a class="text-link" href="/cv">CV</a>
        <a class="text-link" href="/contact">Contact</a>
      </div>
    </div>

    <div class="hero-image-wrap">
      <div class="hero-side">
        <div class="hero-image-card">
          <img src="/images/ny-profile.jpg" alt="Portrait of Sarakpy NY" />
        </div>

        <div class="profile-links" aria-label="Contact links">
          <a
            href="mailto:sarakpy.ny@ensae.fr"
            target="_blank"
            rel="noopener noreferrer"
          >
            Email
          </a>
          <a
            href="https://github.com/sarakpyny"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/sarakpyny/"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Current & Recent Work</h2>
    </div>

    <div class="academic-list">
      <article class="academic-item">
        <h3>Scientific Machine Learning Internship</h3>
        <p class="meta">
          <a
            href="https://www.imt-atlantique.fr/"
            target="_blank"
            rel="noopener noreferrer">IMT Atlantique</a
          >
          &amp;
          <a
            href="https://www.inria.fr/en/odyssey"
            target="_blank"
            rel="noopener noreferrer">INRIA Odyssey</a
          >
          · 2026
        </p>
        <p>
          Research on active learning methods for the correction of numerical
          models, with a focus on neural subgrid-scale parameterization.
        </p>
      </article>

      <article class="academic-item">
        <h3>Machine Learning Research Internship</h3>
        <p class="meta">
          <a
            href="https://crest.science/"
            target="_blank"
            rel="noopener noreferrer">CREST</a
          >
          –
          <a
            href="https://www.ip-paris.fr/"
            target="_blank"
            rel="noopener noreferrer">IP Paris</a
          >
          · 2025
        </p>
        <p>
          Worked on memory compression in LSTMs via information-theoretic
          projection, in connection with sequence models and representation
          efficiency.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Selected Projects</h2>
      <a class="text-link" href="/projects">See all projects</a>
    </div>

    <article class="project-card">
      <p class="project-tag">MLOps · Deployment · 2026</p>
      <h3>ML System Deployment</h3>
      <p>
        Built a reproducible machine learning system with modular training
        pipelines, experiment tracking, API serving, CI/CD, and Kubernetes
        deployment.
      </p>
      <p class="project-links">
        <a
          href="https://github.com/sarakpyny/MLOps-nlp-manifesto"
          target="_blank"
          rel="noopener noreferrer"
        >
          Code
        </a>
      </p>
    </article>

    <article class="project-card">
      <p class="project-tag">Fairness in ML · 2025</p>
      <h3>Fairness via Representation Neutralization</h3>
      <p>
        Studied fairness-aware classification on the COMPAS dataset and examined
        the trade-off between predictive performance and fairness metrics.
      </p>
      <p class="project-links">
        <a
          href="https://github.com/sarakpyny/fairness-via-representation-neutralization"
          target="_blank"
          rel="noopener noreferrer"
        >
          Code
        </a>
      </p>
    </article>

    <article class="project-card">
      <p class="project-tag">Probability · Monte Carlo · 2024</p>
      <h3>Probabilistic Couplings</h3>
      <p>
        Investigated couplings of probability distributions with high
        probability of equality using probabilistic reasoning and Monte Carlo
        methods.
      </p>
      <p class="project-links">
        <a
          href="https://github.com/pieropls/MCProj-Coupling"
          target="_blank"
          rel="noopener noreferrer"
        >
          Code
        </a>
      </p>
    </article>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 2rem;
    align-items: start;
    padding: 0.4rem 0 0.8rem;
  }

  .hero-text {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6b7280;
  }

  h1 {
    font-size: clamp(1.7rem, 3.2vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 0.55rem;
    font-weight: 600;
  }

  .subtitle {
    font-size: 1.05rem;
    line-height: 1.55;
    color: #1f4b5c;
    margin: 0 0 1rem;
    max-width: none;
  }

  .subtitle a {
    color: #1f4b5c;
    text-decoration: none;
    font-weight: 500;
  }

  .subtitle a:hover {
    color: #1f4b5c;
    text-decoration: underline;
  }
  .lead a {
    color: #1f4b5c;
    text-decoration: none;
    font-weight: 500;
  }

  .lead a:hover {
    color: #1f4b5c;
    text-decoration: underline;
  }

  .lead {
    max-width: none;
  }

  .lead p {
    font-size: 1rem;
    line-height: 1.8;
    color: #374151;
    margin: 0 0 0.95rem;
  }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.68rem 0.95rem;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    text-decoration: none;
    color: #111827;
    background: #ffffff;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .button.primary {
    background: #111827;
    color: #ffffff;
    border-color: #111827;
  }

  .text-link {
    color: #1f4b5c;
    text-decoration: none;
    font-weight: 500;
  }

  .text-link:hover {
    text-decoration: underline;
  }

  .hero-image-wrap {
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    padding-top: 0.2rem;
  }

  .hero-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-image-card {
    width: 100%;
    max-width: 200px;
    padding: 0.45rem;
    background: #ffffff;
    border: 1px solid #dfe3e8;
    border-radius: 12px;
  }

  .hero-image-card img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 8px;
  }

  .hero-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
  }

  .profile-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .profile-links a {
    color: #4b5563;
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .profile-links a:hover {
    color: #1f4b5c;
    text-decoration: underline;
  }

  .profile-links img {
    width: 16px;
    height: 16px;
    display: block;
  }

  .section {
    margin-top: 3rem;
  }

  .section-narrow {
    margin-top: 2.2rem;
  }

  .section-block {
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
  }

  .section h2 {
    font-size: 1.4rem;
    line-height: 1.25;
    margin: 0 0 0.85rem;
    letter-spacing: -0.02em;
    font-weight: 600;
  }

  .inline-topics {
    margin: 0;
    color: #4b5563;
    line-height: 1.8;
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .academic-list {
    display: grid;
    gap: 1rem;
  }

  .academic-item {
    padding: 1.1rem 0 1.2rem;
    border-top: 1px solid #e5e7eb;
  }

  .academic-item:last-child {
    border-bottom: 1px solid #e5e7eb;
  }

  .academic-item h3 {
    margin: 0 0 0.25rem;
    font-size: 1.08rem;
    line-height: 1.4;
    font-weight: 600;
  }

  .academic-item .meta {
    margin: 0 0 0.55rem;
    font-size: 0.92rem;
    color: #6b7280;
  }

  .academic-item .meta a {
    color: #1f4b5c;
    text-decoration: none;
    font-weight: 500;
  }

  .academic-item .meta a:hover {
    color: #1f4b5c;
    text-decoration: underline;
  }

  .academic-item p:last-child {
    margin: 0;
    line-height: 1.75;
    color: #374151;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid #e5e7eb;
  }

  .project-card {
    background: transparent;
    border: 0;
    border-bottom: 1px solid #e5e7eb;
    border-radius: 0;
    padding: 1.15rem 0 1.2rem;
    min-height: unset;
    box-shadow: none;
    transition: none;
  }

  .project-card:hover {
    transform: none;
    box-shadow: none;
    border-color: #e5e7eb;
  }

  .project-tag {
    margin: 0 0 0.3rem;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #6b7280;
  }

  .project-card h3 {
    margin: 0 0 0.45rem;
    font-size: 1.08rem;
    line-height: 1.4;
  }

  .project-card h3 a {
    color: #1f4b5c;
    text-decoration: none;
    font-weight: inherit;
  }

  .project-card h3 a:hover {
    color: #1f4b5c;
    text-decoration: underline;
  }

  .project-card p:last-child {
    margin: 0;
    max-width: 75ch;
    color: #374151;
    line-height: 1.75;
    font-size: 0.98rem;
  }

  .project-card > p:not(.project-tag):not(.project-links) {
    margin: 0;
    max-width: 75ch;
    color: #374151;
    line-height: 1.75;
    font-size: 0.98rem;
  }

  .project-links {
    margin: 0.55rem 0 0;
  }

  .project-links a {
    color: #1f4b5c;
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .project-links a:hover {
    color: #1f4b5c;
    text-decoration: underline;
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hero-image-wrap {
      justify-content: flex-start;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 2.2rem;
    }

    .section-heading {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
