---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sarakpy NY">
  <section class="hero">
    <div class="hero-text">
      <h1>Sarakpy NY</h1>

      <p class="subtitle">
        Data Science, Statistics, and Machine Learning student at ENSAE -
        IP-Paris
      </p>

      <div class="lead">
        <p>
          I study data science, statistics, and machine learning at ENSAE -
          IP-Paris, with a background in applied mathematics and statistics.
        </p>
        <p>
          I am interested in scientific machine learning, especially active
          learning, and in research that connects mathematical modeling with
          modern machine learning.
        </p>
      </div>

      <div class="button-group">
        <a class="button primary" href="/projects">View Projects</a>
        <a class="button" href="/cv">View CV</a>
        <a class="button" href="/contact">Contact</a>
      </div>
    </div>

    <div class="hero-image-wrap">
      <div class="hero-image-card">
        <img src="/images/ny-profile.jpg" alt="Portrait of Sarakpy NY" />
      </div>
    </div>
  </section>

  <!-- <section class="section">
    <div class="section-card compact">
      <h2>Research Interests</h2>
      <p>
        Scientific machine learning, active learning, statistical learning, and
        probabilistic modeling.
      </p>
    </div>
  </section> -->

  <section class="section">
    <div class="section-heading">
      <h2>Selected Projects</h2>
      <a class="text-link" href="/projects">See all projects</a>
    </div>

    <div class="project-grid">
      <article class="project-card">
        <h3>ML System Deployment</h3>
        <p>
          Built and deployed a reproducible machine learning system with modular
          pipelines, experiment tracking, API serving, CI/CD, and Kubernetes
          deployment.
        </p>
      </article>

      <article class="project-card">
        <h3>Fairness in Classification</h3>
        <p>
          Studied fairness-aware classification on the COMPAS dataset and
          examined the trade-off between predictive performance and fairness
          metrics.
        </p>
      </article>

      <article class="project-card">
        <h3>Monte Carlo for Probabilistic Couplings</h3>
        <p>
          Investigated couplings of probability distributions with high
          probability of equality using probabilistic reasoning and Monte Carlo
          methods.
        </p>
      </article>
    </div>
  </section>

  <style>
    .hero {
      display: grid;
      grid-template-columns: minmax(0, 700px) 240px;
      gap: 1.25rem;
      align-items: start;
      justify-content: space-between;
      padding: 0.2rem 0 0.4rem;
    }

    h1 {
      font-size: clamp(1.8rem, 3.2vw, 2.5rem);
      line-height: 1.08;
      letter-spacing: -0.02em;
      margin: 0 0 0.5rem;
      max-width: none;
    }

    .subtitle {
      color: #25627a;
      font-size: 1rem;
      line-height: 1.45;
      margin: 0 0 1rem;
    }

    .lead {
      max-width: 58ch;
    }

    .lead p {
      font-size: 1rem;
      line-height: 1.75;
      color: #374151;
      margin: 0 0 0.9rem;
    }

    .button-group {
      display: flex;
      gap: 0.7rem;
      margin-top: 1.2rem;
      flex-wrap: wrap;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.68rem 0.95rem;
      border: 1px solid #d1d5db;
      border-radius: 10px;
      text-decoration: none;
      color: #111827;
      background: #ffffff;
      font-weight: 500;
      font-size: 0.95rem;
    }

    .button:hover {
      transform: translateY(-1px);
      border-color: #9ca3af;
      box-shadow: 0 8px 24px rgba(17, 24, 39, 0.06);
    }

    .button.primary {
      background: #111827;
      color: white;
      border-color: #111827;
    }

    .hero-text {
      max-width: 700px;
    }

    .hero-image-wrap {
      display: flex;
      justify-content: flex-end;
      align-items: flex-start;
      padding-top: 0.3rem;
    }

    .hero-image-card {
      width: 100%;
      max-width: 240px;
      padding: 0.6rem;
      background: linear-gradient(180deg, #ffffff 0%, #f3f4f6 100%);
      border: 1px solid #e5e7eb;
      border-radius: 22px;
      box-shadow: 0 18px 40px rgba(17, 24, 39, 0.08);
    }

    .hero-image-card img {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 18px;
    }

    .section {
      margin-top: 3.5rem;
    }

    .section-card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 20px;
      padding: 1.5rem 1.4rem;
      box-shadow: 0 10px 30px rgba(17, 24, 39, 0.04);
    }

    .section-card.compact p {
      margin: 0;
      line-height: 1.8;
      color: #374151;
    }

    .section h2,
    .section-card h2 {
      font-size: 1.8rem;
      line-height: 1.2;
      margin: 0 0 0.9rem;
      letter-spacing: -0.02em;
    }

    .section-heading {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .text-link {
      color: #2563eb;
      text-decoration: none;
      font-weight: 500;
    }

    .text-link:hover {
      text-decoration: underline;
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.1rem;
    }

    .project-card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      padding: 1.35rem 1.2rem;
      box-shadow: 0 10px 30px rgba(17, 24, 39, 0.04);
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease,
        border-color 0.15s ease;
      min-height: 210px;
    }

    .project-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 34px rgba(17, 24, 39, 0.08);
      border-color: #d1d5db;
    }

    .project-card h3 {
      margin: 0 0 0.75rem;
      font-size: 1.2rem;
      line-height: 1.35;
      letter-spacing: -0.01em;
    }

    .project-card p {
      margin: 0;
      color: #374151;
      line-height: 1.75;
      font-size: 1rem;
    }

    @media (max-width: 980px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 2.2rem;
        padding-top: 1.5rem;
      }

      .hero-image-wrap {
        justify-content: flex-start;
      }

      h1 {
        max-width: 11ch;
      }

      .project-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      h1 {
        font-size: 2.5rem;
        max-width: none;
      }

      .section-heading {
        flex-direction: column;
        align-items: flex-start;
      }

      .section-card,
      .project-card {
        padding: 1.15rem 1rem;
      }
    }
  </style>
</BaseLayout>
