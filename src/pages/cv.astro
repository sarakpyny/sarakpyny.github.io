---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CV | Sarakpy Ny">
  <section class="page">
    <h1>CV</h1>

    <!-- <p class="intro">
      I am a Master's student in Data Science, Statistics, and Machine Learning
      at ENSAE Paris, Institut Polytechnique de Paris, with experience across
      applied data science and research-oriented machine learning.
    </p> -->

    <div class="cv-section">
      <h2>Education</h2>

      <div class="entry">
        <div class="entry-head">
          <h3>ENSAE Paris – Institut Polytechnique de Paris</h3>
          <p class="date">2022–2026</p>
        </div>
        <p>
          Master's of Science (MSc), specializing in Data Science, Statistics,
          and Machine Learning.
        </p>
      </div>

      <div class="entry">
        <div class="entry-head">
          <h3>Institute of Technology of Cambodia</h3>
          <p class="date">2019–2022</p>
        </div>
        <p>
          Engineering program, specializing in Applied Mathematics and
          Statistics.
        </p>
      </div>
    </div>

    <div class="cv-section">
      <h2>Selected Experience</h2>

      <div class="entry">
        <div class="entry-head">
          <h3>IMT Atlantique &amp; INRIA Odyssey</h3>
          <p class="date">2026</p>
        </div>
        <p>
          Scientific Machine Learning internship on active learning methods for
          the correction of numerical models, with a focus on neural
          subgrid-scale parameterization.
        </p>
      </div>

      <div class="entry">
        <div class="entry-head">
          <h3>CREST – IP Paris</h3>
          <p class="date">2025</p>
        </div>
        <p>
          Research internship on memory compression in LSTMs via
          information-theoretic projection, in connection with sequence models
          and representation efficiency.
        </p>
      </div>

      <div class="entry">
        <div class="entry-head">
          <h3>Carrefour</h3>
          <p class="date">2024–2025</p>
        </div>
        <p>
          Worked on prediction of product repurchase using customers’ purchase
          history in a recommendation setting.
        </p>
      </div>

      <div class="entry">
        <div class="entry-head">
          <h3>Ministry of Ecology and Territories</h3>
          <p class="date">2024</p>
        </div>
        <p>
          Contributed to the estimation of housing energy performance by
          improving prediction methodology with machine learning and confidence
          indicators.
        </p>
      </div>
    </div>

    <div class="cv-section">
      <h2>Skills</h2>
      <p>
        <strong>Programming:</strong> Python, R, SAS, Stata
      </p>
      <p>
        <strong>Databases:</strong> SQL, PostgreSQL
      </p>
      <p>
        <strong>Tools:</strong> Git, MLflow, Docker, Kubernetes, FastAPI, Streamlit,
        LaTeX
      </p>
    </div>

    <div class="cv-actions">
      <a
        class="button primary"
        href="/files/cv.pdf"
        target="_blank"
        rel="noopener noreferrer"
      >
        Download CV (PDF)
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    max-width: 820px;
  }

  h1 {
    font-size: 1.9rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 0.8rem;
    font-weight: 600;
  }

  .intro {
    margin: 0 0 1.8rem;
    color: #374151;
    font-size: 1rem;
    line-height: 1.8;
  }

  .cv-section {
    margin-top: 2rem;
  }

  .cv-section h2 {
    font-size: 1.15rem;
    line-height: 1.3;
    margin: 0 0 0.9rem;
    font-weight: 600;
  }

  .entry {
    padding: 1rem 0;
    border-top: 1px solid #e5e7eb;
  }

  .entry:last-child {
    border-bottom: 1px solid #e5e7eb;
  }

  .entry-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.3rem;
  }

  .entry-head h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
    font-weight: 600;
  }

  .date {
    margin: 0;
    font-size: 0.92rem;
    color: #6b7280;
    white-space: nowrap;
  }

  .entry p,
  .cv-section > p {
    margin: 0;
    color: #374151;
    line-height: 1.75;
    font-size: 0.98rem;
  }

  .cv-section > p + p {
    margin-top: 0.45rem;
  }

  .cv-actions {
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.68rem 0.95rem;
    border: 1px solid #111827;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .button.primary {
    background: #111827;
    color: #ffffff;
  }

  .button.primary:hover {
    opacity: 0.95;
  }

  @media (max-width: 640px) {
    .entry-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.15rem;
    }

    .date {
      white-space: normal;
    }
  }
</style>
