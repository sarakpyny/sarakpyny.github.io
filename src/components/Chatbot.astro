---
const apiUrl = "https://sarakpy-chatbot-backend.vercel.app/api/chat";
---

<div id="chatbot-root">
    <button id="chat-toggle" aria-label="Open chatbot">Ask about Sarakpy</button
    >

    <div id="chat-window" class="hidden">
        <div class="chat-header">
            <strong>Ask about Sarakpy</strong>
            <button id="chat-close" aria-label="Close chatbot">×</button>
        </div>

        <div id="chat-messages">
            <div class="message bot">
                Hi — I can answer questions about Sarakpy’s background,
                projects, CV, research interests, and contact details.
            </div>
        </div>

        <form id="chat-form">
            <input
                id="chat-input"
                type="text"
                placeholder="Ask something..."
                autocomplete="off"
                required
            />
            <button type="submit">Send</button>
        </form>
    </div>
</div>

<style is:global>
    #chatbot-root {
        position: fixed;
        right: 1.5rem;
        bottom: 1.5rem;
        z-index: 1000;
        font-family: inherit;
    }

    #chatbot-root #chat-toggle {
        border: 1px solid var(--line, #d1d5db);
        background: var(--card, #ffffff);
        color: var(--text, #111827);
        padding: 0.9rem 1.2rem;
        border-radius: 999px;
        cursor: pointer;
        box-shadow: 0 14px 35px rgba(17, 24, 39, 0.14);
        font-size: 0.95rem;
        font-weight: 500;
    }

    #chatbot-root #chat-window {
        width: min(420px, calc(100vw - 2rem));
        height: min(600px, calc(100vh - 7rem));
        margin-bottom: 0.9rem;
        border: 1px solid var(--line, #d1d5db);
        background: var(--card, #ffffff);
        color: var(--text, #111827);
        border-radius: 22px;
        box-shadow: 0 24px 60px rgba(17, 24, 39, 0.18);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    #chatbot-root #chat-window.hidden {
        display: none;
    }

    #chatbot-root .chat-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1rem 0.9rem;
        border-bottom: 1px solid var(--line, #e5e7eb);
        background: var(--card, #ffffff);
    }

    #chatbot-root #chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.1rem;
        background: var(--bg-soft-2, var(--bg, #f8fafc));
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }

    #chatbot-root .message {
        max-width: 82%;
        margin-bottom: 0.4rem;
        padding: 0.85rem 1rem;
        border-radius: 18px;
        line-height: 1.55;
        font-size: 0.95rem;
        white-space: normal;
        text-align: left;
        overflow-wrap: break-word;
    }

    #chatbot-root .message.bot {
        background: var(--card, #ffffff);
        border: 1px solid var(--line, #e5e7eb);
        color: var(--text, #111827);
        margin-right: auto;
        border-top-left-radius: 8px;
    }

    #chatbot-root .message.user {
        margin-left: auto;
        background: var(--text, #111827);
        color: var(--bg, #ffffff);
        border: 1px solid var(--text, #111827);
        border-top-right-radius: 8px;
    }

    #chatbot-root #chat-form {
        display: flex;
        gap: 0.4rem;
        padding: 1rem;
        border-top: 1px solid var(--line, #e5e7eb);
        background: var(--card, #ffffff);
    }

    #chatbot-root #chat-input {
        flex: 1;
        border: 1px solid var(--line, #d1d5db);
        border-radius: 14px;
        padding: 0.8rem 0.9rem;
        font: inherit;
        font-size: 0.94rem;
        background: var(--bg, #ffffff);
        color: var(--text, #111827);
    }

    #chatbot-root #chat-form button {
        border: none;
        border-radius: 14px;
        padding: 0.8rem 1rem;
        cursor: pointer;
        background: var(--text, #111827);
        color: var(--bg, #ffffff);
        font: inherit;
        font-size: 0.92rem;
        font-weight: 500;
    }
</style>

<script>
    const apiUrl = "https://sarakpy-chatbot-backend.vercel.app/api/chat";

    const toggleBtn = document.getElementById("chat-toggle");
    const closeBtn = document.getElementById("chat-close");
    const chatWindow = document.getElementById("chat-window");
    const form = document.getElementById("chat-form");
    const input = document.getElementById("chat-input");
    const messages = document.getElementById("chat-messages");
    // const suggestionButtons = document.querySelectorAll(".suggestion");

    function addMessage(text, sender) {
        const div = document.createElement("div");
        div.className = `message ${sender}`;
        div.textContent = text;
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
    }

    async function sendMessage(question) {
        addMessage(question, "user");
        addMessage("Thinking...", "bot");

        try {
            const response = await fetch(apiUrl, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({
                    message: question,
                    page: window.location.pathname,
                }),
            });

            const data = await response.json();

            const thinking = messages.querySelector(".message.bot:last-child");
            if (thinking && thinking.textContent === "Thinking...") {
                thinking.remove();
            }

            addMessage(data.reply || "Sorry, something went wrong.", "bot");
        } catch (error) {
            const thinking = messages.querySelector(".message.bot:last-child");
            if (thinking && thinking.textContent === "Thinking...") {
                thinking.remove();
            }

            addMessage("Sorry, I could not reach the chatbot service.", "bot");
            console.error(error);
        }
    }

    toggleBtn?.addEventListener("click", () => {
        chatWindow?.classList.toggle("hidden");
    });

    closeBtn?.addEventListener("click", () => {
        chatWindow?.classList.add("hidden");
    });

    form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const question = input.value.trim();
        if (!question) return;

        input.value = "";
        await sendMessage(question);
    });

    // suggestionButtons.forEach((button) => {
    //     button.addEventListener("click", async () => {
    //         const question = button.getAttribute("data-question");
    //         if (!question) return;
    //         await sendMessage(question);
    //     });
    // });
</script>
