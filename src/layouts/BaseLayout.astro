---
const { title = "Sarakpy NY" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f8f9fb;
        --text: #1f2937;
        --muted: #4b5563;
        --line: #d1d5db;
        --accent: #1d4ed8;
        --card: #ffffff;
        --max-width: 900px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      header {
        border-bottom: 1px solid var(--line);
        background: rgba(248, 249, 251, 0.95);
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .nav-name {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--text);
      }

      .nav-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }

      main {
        padding: 3rem 0;
      }

      h1, h2, h3 {
        line-height: 1.2;
        margin-top: 0;
      }

      h1 {
        font-size: 2.4rem;
        margin-bottom: 1rem;
      }

      h2 {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
        margin-top: 2.5rem;
      }

      p {
        margin: 0 0 1rem 0;
      }

      .muted {
        color: var(--muted);
      }

      .button-group {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .button {
        display: inline-block;
        padding: 0.7rem 1rem;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: var(--card);
        color: var(--text);
        font-weight: 500;
      }

      .button.primary {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
      }

      .section {
        margin-top: 3rem;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 1.2rem;
        margin-bottom: 1rem;
      }

      footer {
        border-top: 1px solid var(--line);
        padding: 1.5rem 0 2rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      img {
        max-width: 100%;
        display: block;
      }

      @media (max-width: 700px) {
        h1 {
          font-size: 2rem;
        }

        .nav {
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container nav">
        <a href="/" class="nav-name">Sarakpy NY</a>
        <nav class="nav-links">
          <a href="/about">About</a>
          <a href="/projects">Projects</a>
          <a href="/cv">CV</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        © 2026 Sarakpy NY
      </div>
    </footer>
  </body>
</html>