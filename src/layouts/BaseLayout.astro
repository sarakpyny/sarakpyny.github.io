---
const { title = "Sarakpy Ny" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      const theme = savedTheme || (prefersDark ? "dark" : "light");
      document.documentElement.setAttribute("data-theme", theme);
    </script>

    <style>
      :root {
        --bg: #fcfcfd;
        --bg-soft-1: #f3f6fb;
        --bg-soft-2: #f8fafc;
        --surface: rgba(255, 255, 255, 0.82);
        --card: #ffffff;
        --text: #111827;
        --muted: #6b7280;
        --line: #e5e7eb;
        --line-strong: #d1d5db;
        --accent: #163b66;
        --accent-dark: #122f52;
        --nav-link: #1f2937;
        --button-primary-bg: #111827;
        --button-primary-hover: #0f172a;
        --shadow-soft: 0 10px 30px rgba(17, 24, 39, 0.04);
        --max-width: 1120px;
        --content-width: 760px;
        --radius: 18px;
      }

      html[data-theme="dark"] {
        --bg: #0b1220;
        --bg-soft-1: #111827;
        --bg-soft-2: #0f172a;
        --surface: rgba(15, 23, 42, 0.82);
        --card: #111827;
        --text: #e5e7eb;
        --muted: #94a3b8;
        --line: #243042;
        --line-strong: #334155;
        --accent: #8fb4e5;
        --accent-dark: #b6d0f2;
        --nav-link: #d1d5db;
        --button-primary-bg: #e5e7eb;
        --button-primary-hover: #cbd5e1;
        --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.22);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family:
          Inter,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          sans-serif;
        background:
          radial-gradient(
            circle at top left,
            var(--bg-soft-1) 0%,
            transparent 30%
          ),
          radial-gradient(
            circle at top right,
            var(--bg-soft-2) 0%,
            transparent 25%
          ),
          var(--bg);
        color: var(--text);
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        transition:
          background-color 0.2s ease,
          color 0.2s ease;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s ease;
      }

      a:hover {
        color: var(--accent-dark);
      }

      .container {
        width: min(var(--max-width), calc(100% - 2rem));
        margin: 0 auto;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid var(--line);
        background: var(--surface);
        backdrop-filter: blur(10px);
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        min-height: 72px;
        gap: 1.25rem;
      }

      .nav-name {
        font-weight: 700;
        font-size: 1.15rem;
        letter-spacing: -0.02em;
        color: var(--text);
      }

      .nav-name:hover {
        color: var(--text);
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      .nav-links a {
        color: var(--nav-link);
        font-weight: 500;
        font-size: 0.98rem;
      }

      .nav-links a:hover {
        color: var(--accent);
        text-decoration: none;
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--nav-link);
        cursor: pointer;
        font-size: 1.05rem;
        line-height: 1;
      }

      .theme-toggle:hover {
        color: var(--accent);
        transform: none;
      }

      main {
        padding: 2.2rem 0 4.2rem;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin-top: 0;
        color: var(--text);
      }

      h1 {
        font-size: clamp(2.6rem, 6vw, 4.5rem);
        margin-bottom: 1.2rem;
      }

      h2 {
        font-size: 1.9rem;
        margin-bottom: 0.9rem;
      }

      h3 {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
      }

      p {
        margin: 0 0 1rem 0;
      }

      .prose {
        max-width: var(--content-width);
      }

      .muted {
        color: var(--muted);
      }

      .button-group {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.76rem 1.08rem;
        border: 1px solid var(--line-strong);
        border-radius: 12px;
        background: var(--card);
        color: var(--text);
        font-weight: 500;
        text-decoration: none;
        transition:
          transform 0.15s ease,
          box-shadow 0.15s ease,
          border-color 0.15s ease,
          background 0.15s ease,
          color 0.15s ease;
      }

      .button:hover {
        text-decoration: none;
        transform: translateY(-1px);
        box-shadow: var(--shadow-soft);
        border-color: var(--accent);
      }

      .button.primary {
        background: var(--button-primary-bg);
        color: var(--bg);
        border-color: var(--button-primary-bg);
      }

      .button.primary:hover {
        background: var(--button-primary-hover);
        border-color: var(--button-primary-hover);
      }

      html[data-theme="dark"] .button.primary {
        color: #0b1220;
      }

      .section {
        margin-top: 4rem;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1.35rem;
        box-shadow: var(--shadow-soft);
      }

      .site-footer {
        border-top: 1px solid var(--line);
        padding: 1.5rem 0 2.5rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: flex-start;
      }

      .footer-inline {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        flex-wrap: wrap;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .footer-inline a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        text-decoration: none;
      }

      .footer-inline a:hover {
        color: var(--text);
      }

      .footer-inline img {
        width: 15px;
        height: 15px;
        display: block;
        filter: none;
      }

      html[data-theme="dark"] .footer-inline img {
        filter: invert(92%) sepia(8%) saturate(192%) hue-rotate(180deg)
          brightness(95%) contrast(90%);
      }

      .footer-note {
        margin-left: 0.15rem;
      }

      img {
        max-width: 100%;
        display: block;
      }

      @media (max-width: 900px) {
        main {
          padding: 3rem 0 4rem;
        }
      }

      @media (max-width: 700px) {
        .nav {
          align-items: flex-start;
          padding: 0.9rem 0;
        }

        .nav-right {
          display: flex;
          align-items: center;
          gap: 1rem;
        }

        .nav-links {
          gap: 1rem;
        }

        h2 {
          font-size: 1.6rem;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <div class="container nav">
        <a href="/" class="nav-name">N. Sarakpy</a>

        <div class="nav-right">
          <nav class="nav-links">
            <a href="/about">About</a>
            <a href="/projects">Projects</a>
            <a href="/cv">CV</a>
            <a href="/contact">Contact</a>
          </nav>

          <button
            id="theme-toggle"
            class="theme-toggle"
            type="button"
            aria-label="Toggle dark mode"
            title="Toggle dark mode"
          >
            ☾
          </button>
        </div>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-inline">
          <span>© Sarakpy Ny — last updated: Apr 2026</span>

          <a
            href="https://github.com/sarakpyny"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
          >
            <img src="/icons/github.svg" alt="GitHub" />
          </a>

          <a
            href="https://www.linkedin.com/in/sarakpyny/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <img src="/icons/linkedin.svg" alt="LinkedIn" />
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const toggleButton = document.getElementById("theme-toggle");

      toggleButton?.addEventListener("click", () => {
        const currentTheme =
          document.documentElement.getAttribute("data-theme");
        const nextTheme = currentTheme === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", nextTheme);
        localStorage.setItem("theme", nextTheme);
      });
    </script>
  </body>
</html>
